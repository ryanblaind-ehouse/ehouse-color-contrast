{
  "name": "ehouse-color-contrast",
  "version": "1.0.0",
  "description": "Experimental accessible color matrix tool",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "start": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "test": "vitest run",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "ui": "shadcn",
    "ui:add": "shadcn add",
    "ui:view": "shadcn view",
    "ui:search": "shadcn search @shadcn",
    "ui:info": "shadcn info",
    "ui:docs": "shadcn docs",
    "ui:mcp:init": "shadcn mcp init"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanblaind-ehouse/ehouse-color-contrast.git"
  },
  "author": "ryanblaind-ehouse",
  "license": "CC0-1.0",
  "bugs": {
    "url": "https://github.com/ryanblaind-ehouse/ehouse-color-contrast/issues"
  },
  "homepage": "https://github.com/ryanblaind-ehouse/ehouse-color-contrast#readme",
  "dependencies": {
    "apca-w3": "^0.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "extract-colors": "^4.2.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "shadcn": "^4.0.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
